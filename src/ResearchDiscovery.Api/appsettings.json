{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=researchdb;Username=research;Password=devonly"
  },
  "Arxiv": {
    "BaseUrl": "https://export.arxiv.org/api/query",
    "Categories": [ "cs.LG", "cs.AI", "cs.CR", "cs.SE", "q-fin.CP", "q-fin.TR" ],
    "PageSize": 100,
    "MinRequestIntervalSeconds": 3,
    "MaxRetries": 3,
    "RetryBaseDelaySeconds": 5
  },
  "Ingestion": {
    "Backfill": {
      "WindowDays": 90,
      "MaxPapersPerCategory": 10000
    },
    "Schedule": {
      "Enabled": true,
      "TimeUtc": "06:30"
    },
    "LockStaleAfterMinutes": 120
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Llm": {
    "Models": [
      {
        "Id": "claude-haiku-4-5",
        "DisplayName": "Claude Haiku 4.5",
        "InputPerMTok": 1.00,
        "OutputPerMTok": 5.00
      },
      {
        "Id": "claude-sonnet-5",
        "DisplayName": "Claude Sonnet 5",
        "InputPerMTok": 3.00,
        "OutputPerMTok": 15.00
      },
      {
        "Id": "claude-opus-4-8",
        "DisplayName": "Claude Opus 4.8",
        "InputPerMTok": 5.00,
        "OutputPerMTok": 25.00
      }
    ],
    "Defaults": {
      "QueryCompiler": "claude-haiku-4-5",
      "PaperAnalysis": "claude-haiku-4-5",
      "RelevanceJudge": "claude-haiku-4-5"
    }
  },
  "Embeddings": {
    "Enabled": true,
    "ModelVersion": "all-MiniLM-L6-v2",
    "ModelDirectory": "models/all-MiniLM-L6-v2"
  },
  "Admin": {
    "ApiKey": ""
  }
}
