{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=researchdb;Username=research;Password=devonly"
  },
  "Arxiv": {
    "BaseUrl": "https://export.arxiv.org/api/query",
    "Categories": [ "cs.LG", "cs.AI", "cs.CR", "cs.SE", "q-fin.CP", "q-fin.TR" ],
    "PageSize": 100,
    "MinRequestIntervalSeconds": 3,
    "MaxRetries": 3,
    "RetryBaseDelaySeconds": 5
  },
  "Ingestion": {
    "Backfill": {
      "WindowDays": 90,
      "MaxPapersPerCategory": 10000
    },
    "Schedule": {
      "Enabled": true,
      "TimeUtc": "06:30"
    },
    "LockStaleAfterMinutes": 120
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Admin": {
    "ApiKey": ""
  }
}
